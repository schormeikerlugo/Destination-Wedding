---
import "./Packages.css";
import { packages } from "@data/packages";
---

<section
  class="invest section"
  id="investment"
  aria-labelledby="invest-title"
>
  <div class="container invest__header">
    <div>
      <p class="t-mono">05 / Investment</p>
      <h2
        id="invest-title"
        class="invest__title t-display-bold"
        data-invest-title
      >
        <span class="invest__title-line"><span>Designed</span></span>
        <span class="invest__title-line"><span>for every</span></span>
        <span class="invest__title-line"><span>horizon.</span></span>
      </h2>
    </div>
    <div class="invest__intro">
      <p class="t-body">
        Each package includes coverage, hand-crafted editing and a private
        online gallery. Custom packages — additional days, a second shooter,
        film hybrid coverage — are always available.
      </p>
    </div>
  </div>

  <div class="container">
    <ul role="list" class="invest__grid" data-invest-grid>
      {
        packages.map((pkg) => (
          <li
            class:list={[
              "invest-card",
              pkg.featured && "invest-card--featured",
            ]}
            data-invest-card
          >
            {pkg.featured && pkg.featuredLabel && (
              <span class="invest-card__badge t-mono">
                {pkg.featuredLabel}
              </span>
            )}

            <span class="invest-card__tier t-mono">{pkg.tier}</span>

            <h3 class="invest-card__title">{pkg.region}</h3>

            <p class="invest-card__price">
              <span class="invest-card__price-value">{pkg.price}</span>
              {pkg.priceUnit && (
                <span class="invest-card__price-unit">{pkg.priceUnit}</span>
              )}
            </p>

            <p class="invest-card__blurb">{pkg.blurb}</p>

            <ul role="list" class="invest-card__list">
              {pkg.destinations.slice(0, 4).map((d) => (
                <li>{d}</li>
              ))}
            </ul>

            <a
              href="#cta"
              class="invest-card__cta t-mono"
              aria-label={`Inquire about the ${pkg.region} package`}
            >
              <span>Explore</span>
              <span class="invest-card__cta-arrow" aria-hidden="true">↗</span>
            </a>
          </li>
        ))
      }

      <li class="invest-card invest-card--custom" data-invest-card>
        <span class="invest-card__tier t-mono">Type 07</span>
        <h3 class="invest-card__title">Custom</h3>
        <p class="invest-card__price">
          <span class="invest-card__price-value">Tailored</span>
          <span class="invest-card__price-unit">on request</span>
        </p>
        <p class="invest-card__blurb">
          Tell us where, when and what you're imagining. We'll build a bespoke
          package tailored to your day — multi-location, film hybrid, second
          shooter, full editorial production.
        </p>
        <a href="#cta" class="invest-card__cta t-mono" aria-label="Build a custom package">
          <span>Build mine</span>
          <span class="invest-card__cta-arrow" aria-hidden="true">↗</span>
        </a>
      </li>
    </ul>
  </div>
</section>

<script>
  import "./Packages.client";
</script>

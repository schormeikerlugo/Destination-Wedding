---
import "./Hero.css";
import { Image } from "astro:assets";
import Pill from "@ui/Pill.astro";
import heroPhoto from "@assets/hero/lake-kiss.jpg";
import heroPhoto2 from "@assets/hero/dsc1306.jpg";
import heroPhoto3 from "@assets/hero/dsc4673.jpg";
import heroPhoto4 from "@assets/hero/dsc6020.jpg";

const slides = [
  {
    src: heroPhoto,
    alt: "Bride and groom kissing on a balustrade overlooking the Italian lakes",
  },
  {
    src: heroPhoto2,
    alt: "Editorial wedding moment captured in soft natural light",
  },
  {
    src: heroPhoto3,
    alt: "Couple sharing an intimate moment on their wedding day",
  },
  {
    src: heroPhoto4,
    alt: "Quiet editorial portrait from a destination wedding",
  },
];
---

<section class="hero" id="hero" aria-labelledby="hero-title">
  <!-- Full-bleed background photo (carousel: 3 slides, 6s cross-fade) -->
  <div class="hero__media" data-hero-media>
    {slides.map((slide, i) => (
      <Image
        src={slide.src}
        alt={slide.alt}
        class:list={["hero__media-img", i === 0 && "hero__media-img--active"]}
        widths={[960, 1280, 1600, 2000, 2400]}
        sizes="100vw"
        loading={i === 0 ? "eager" : "lazy"}
        decoding="async"
        format="webp"
        quality={88}
        data-hero-slide
        data-index={i}
        aria-hidden={i === 0 ? "false" : "true"}
        {...(i === 0 ? { fetchpriority: "high" } : {})}
      />
    ))}
    <div class="hero__media-overlay" aria-hidden="true"></div>
    <svg class="hero__grain" preserveAspectRatio="none" aria-hidden="true">
      <filter id="hero-grain">
        <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" stitchTiles="stitch" />
        <feColorMatrix type="saturate" values="0" />
      </filter>
      <rect width="100%" height="100%" filter="url(#hero-grain)" />
    </svg>
  </div>

  <!-- Content layer -->
  <div class="hero__shell">
    <div class="container hero__top">
      <p class="t-mono hero__eyebrow" data-hero-eyebrow>
        <span class="hero__dot" aria-hidden="true"></span>
        Est. 2016 · Worldwide
      </p>
      <div class="hero__location" data-hero-location>
        <span class="t-mono">01 — Riva del Garda, Italy</span>
      </div>
    </div>

    <div class="container hero__center">
      <h1 id="hero-title" class="hero__title" data-hero-title>
        <span class="hero__title-line"><span>Destination</span></span>
        <span class="hero__title-line"><span>Weddings</span></span>
      </h1>
    </div>

    <div class="container hero__bottom">
      <div class="hero__lead-card" data-hero-lead>
        <p class="hero__lead-text">
          Editorial wedding experiences from the world’s most breathtaking
          shores. Captured forever, in every fleeting moment.
        </p>
        <div class="hero__cta">
          <Pill href="#cta" variant="invert" size="md" arrow="right">Plan Your Wedding</Pill>
          <Pill href="#work" variant="ghost" size="md" arrow="right">Explore Stories</Pill>
        </div>
      </div>

      <a class="hero__scroll" href="#manifest" aria-label="Scroll to manifesto" data-nav-link data-hero-scroll>
        <span class="t-mono">Scroll</span>
        <span class="hero__scroll-arrow" aria-hidden="true">↓</span>
      </a>
    </div>
  </div>
</section>

<script>
  import "./Hero.client";
</script>
